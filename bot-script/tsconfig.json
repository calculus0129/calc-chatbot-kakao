{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ES2015"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noEmitOnError": true,
    "removeComments": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"]
}
